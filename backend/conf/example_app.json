{
    "app_name": "CloudDisk_Backend",
    "version": 1.0,
    "server": {
        "host": "0.0.0.0",
        "port": 8080,
        "enable_ssl": false
    },
    "database": {
        "host": "127.0.0.1",
        "port": 3306,
        "user": "your_username",
        "password": "your_password",
        "db": "clouddisk"
    },
    "oss":{
        "endpoint": "http://your-oss-endpoint.aliyuncs.com",
        "region": "your-region",
        "bucketName": "your-bucket-name",
        "accessKeyId": "your-access-key-id",
        "accessKeySecret": "your-access-key-secret"
    }
}